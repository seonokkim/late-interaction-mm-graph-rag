# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/

# Environment and secrets
.env
.env.*
*.local.yaml
config.yaml
secrets/

# Packaging
*.egg-info/
.eggs/
dist/
build/
*.egg

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.tox/
htmlcov/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
nosetests.xml

# IDE / OS
.idea/
.vscode/
.cursor/
*.swp
*~
*.orig
*.bak
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Jupyter
.ipynb_checkpoints/

# Logs and temp
*.log
logs/
tmp/
temp/
.cache/
*.tmp
*.temp

# Local env / shell (direnv, etc.)
.envrc

# Experiment tracking & local ML tooling
wandb/
mlruns/
lightning_logs/
tensorboard/
runs/

# Common large / downloaded dumps (if placed outside data/)
downloads/

# Data / checkpoints (large or private)
# Keep empty tree in git via .gitkeep only
data/**
!data/.gitkeep
datasets/
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.bin
*.safetensors

# Run artifacts (pipeline outputs — entire directory)
result/

# Dev documents with possible large attachments (optional — remove if you commit small notes only)
.dev_document/arXiv-*/
